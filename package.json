{
  "name": "@0xarchive/cli",
  "version": "1.4.0",
  "description": "CLI for querying historical crypto market data from 0xArchive",
  "type": "module",
  "bin": {
    "oxa": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "0xarchive",
    "cli",
    "hyperliquid",
    "lighter",
    "orderbook",
    "trades",
    "historical-data",
    "crypto"
  ],
  "author": "0xarchive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xArchiveIO/sdk-typescript"
  },
  "homepage": "https://0xarchive.io/docs/sdks",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@0xarchive/sdk": "^1.4.0",
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
